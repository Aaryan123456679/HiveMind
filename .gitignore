# Go
/engine/bin/
*.test
*.out
/api/api
/engine/engine

# Go workspace (local dev convenience file, not meant to be shared)
go.work
go.work.sum

# Python
agents/.venv/
agents/**/__pycache__/
agents/**/*.egg-info/
*.pyc

# Node/UI
ui/node_modules/
ui/dist/

# HiveMind data-plane artifacts (never commit ingested content or engine state)
/brain/
*.md.v*

# OS
.DS_Store

# Env/secrets
.env
.env.*
!*.env.example

# k8s secret manifests derived from deploy/k8s/*.example.yaml templates (GitHub issue #31
# subtask 6.2.3) -- names only allowed to be committed, real values never.
deploy/k8s/*secret*.yaml
!deploy/k8s/*secret*.example.yaml
