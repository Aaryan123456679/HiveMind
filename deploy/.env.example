# deploy/.env.example -- GitHub issue #31 subtask 6.2.2.
#
# Template for deploy/docker-compose.yml's variable substitution (Compose automatically reads
# a `.env` file located next to the compose file). Copy this to deploy/.env to override the
# demo defaults -- deploy/.env is already covered by the repo root .gitignore's blanket
# `.env`/`.env.*` rules (with a `!*.env.example` carve-out for this file), so it will never be
# committed.
#
#   cp deploy/.env.example deploy/.env
#
# Do NOT put real key values in this .example file -- names only. Real values belong only in
# your untracked deploy/.env (or the repo root's own untracked .env, kept separate).

# Which LLM provider agents/query/server.py's pipeline constructs a client for. Defaults to
# "ollama" in deploy/docker-compose.yml if this var is unset, so `docker compose up` works
# out of the box for a local demo without any real API key. See agents/ LLM provider config
# (docs/LLD/llm-provider.md) for the full list of supported provider names.
LLM_PROVIDER=ollama

# Only needed if you set LLM_PROVIDER to a hosted provider above -- leave unset/commented for
# the default local ollama demo run.
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
